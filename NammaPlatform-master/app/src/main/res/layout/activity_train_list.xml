<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#081B33">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtStation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KSR Bengaluru"
            android:textColor="#F7C948"
            android:textStyle="bold"
            android:textSize="28sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next Trains"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginTop="6dp" />
    </LinearLayout>

    <ListView
        android:id="@+id/trainList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerLayout"
        android:padding="10dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="12dp"
        android:scrollbars="none"/>

    <LinearLayout
        android:id="@+id/btnListenTrains"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="20dp"
        android:background="@android:drawable/presence_online"
        android:backgroundTint="#F7C948"
        android:gravity="center"
        android:orientation="vertical"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="#000000"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Listen"
            android:textStyle="bold"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

</RelativeLayout>